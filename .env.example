# n8n base URL (no trailing slash)
N8N_BASE_URL=https://n8n-production-6e6f5.up.railway.app

# Shared secret — same value as n8n credential "QA Webhook Header Auth"
# Sent only from Next.js Route Handlers as X-QA-Token (never expose to browser)
QA_WEBHOOK_TOKEN=

# Injected into Create-or-Start options so the form stays simple
PLAYWRIGHT_SERVICE_URL=https://playwright-nodejs-production-7e91.up.railway.app
S3_BUCKET=qa-auto-bucket-biv-qk4dkm

# Private S3 (same values as Railway / n8n external storage) — used by FE report proxy
N8N_EXTERNAL_STORAGE_S3_ACCESS_KEY=
N8N_EXTERNAL_STORAGE_S3_ACCESS_SECRET=
N8N_EXTERNAL_STORAGE_S3_BUCKET_NAME=qa-auto-bucket-biv-qk4dkm
N8N_EXTERNAL_STORAGE_S3_BUCKET_REGION=auto
N8N_EXTERNAL_STORAGE_S3_HOST=storage.railway.app

# Optional defaults
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-flash
# Keep crawl small — Railway discover often 502s around ~5m if max_pages is high
# CRAWL_MAX_DEPTH=1
# CRAWL_MAX_PAGES=8
# BROWSER=chromium
# ARTIFACT_BASE_URL=
